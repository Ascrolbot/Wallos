{
    "name": "wallos/quality-assurance-framework",
    "description": "Quality assurance testing framework for Wallos subscription tracker",
    "type": "project",
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "files": [
            "includes/inputvalidation.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M"
    }
}
